# Upstream for wsgi
upstream uwsgi_app {
    server      web:8000;
}

server {
    listen              80;
    server_name         www.altas.com altas.com;
    error_log           stderr warn;
    access_log          /dev/stdout main;

    location / {
        include         /etc/nginx/uwsgi_params;
        uwsgi_pass      uwsgi_app;
    }

    location /static/ {
        alias           /static_root/;
    }

    location /media/ {
        alias           /media_root/;
    }
}